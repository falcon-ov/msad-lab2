    "# 6.2 Проверка стационарности (ADF-тест) и дифференцирование\n",
    "\n",
    "# ADF-тест для исходного дневного ряда\n",
    "result = adfuller(ts_daily.dropna())\n",
    "print('ADF-статистика (исходный ряд): {:.3f}'.format(result[0]))\n",
